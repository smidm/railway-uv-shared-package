{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.13",
    "uv": "latest"
  },
  "steps": {
    "build": {
      "commands": [
        "uv sync --no-dev --no-editable"
      ]
    }
  },
  "deploy": {
    "startCommand": "uv run --no-sync -m uvicorn app.main:app --host 0.0.0.0 --port \"$PORT\""
  }
}
