{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "uv sync --locked --no-dev --no-editable --package app2"
  },
  "deploy": {
    "startCommand": "uv run --no-sync -m uvicorn app2.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/"
  }
}
